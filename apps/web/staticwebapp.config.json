{
  "auth": {
    "identityProviders": {
      "google": {
        "registration": {
          "clientIdSettingName": "GOOGLE_CLIENT_ID",
          "clientSecretSettingName": "GOOGLE_CLIENT_SECRET"
        }
      },
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/common/v2.0",
          "clientIdSettingName": "MICROSOFT_CLIENT_ID",
          "clientSecretSettingName": "MICROSOFT_CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
    {
      "route": "/api/health",
      "allowedRoles": [
        "anonymous",
        "authenticated"
      ]
    },
    {
      "route": "/api/*",
      "allowedRoles": [
        "authenticated"
      ]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/*.{css,js,png,jpg,gif,svg,ico,webp,avif,woff,woff2}"
    ]
  },
  "networking": {
    "allowedIpRanges": [
      "AzureFrontDoor.Backend"
    ]
  },
  "forwardingGateway": {
    "requiredHeaders": {
      "X-Azure-FDID": "b3ff2399-d615-40c3-935c-7f77deaffe64"
    },
    "allowedForwardedHosts": [
      "lbr-prod-edge-f9fzdsa7budefnhg.z01.azurefd.net",
      "www.leaguebrief.com"
    ]
  }
}
